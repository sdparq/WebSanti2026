---
import Figure from './Figure.astro';
import { type Lang, url } from '../i18n/ui';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  lang: Lang;
  ratio?: string;
  index?: number;
}
const { project: p, lang, ratio = '4 / 3', index = 0 } = Astro.props;
const href = url(lang, 'projects', p.slug);
const cover = p.images[0];
---

<a class="card" href={href} data-reveal data-reveal-delay={(index % 3) + 0}>
  <Figure
    src={cover}
    alt={p.title}
    label={cover ? undefined : p.title}
    hue={p.hue}
    ratio={ratio}
    zoom={true}
    class="card__fig"
  />
  <div class="card__meta">
    <h3 class="card__title">{p.title}</h3>
    <p class="card__sub muted">
      {p.location[lang]} · {p.year}
    </p>
  </div>
</a>

<style>
  .card { display: block; }
  .card__fig { margin-bottom: 1rem; }
  .card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .card__title {
    font-size: clamp(1.3rem, 1.1rem + 0.8vw, 1.9rem);
    font-weight: 360;
    transition: color 0.4s var(--ease);
  }
  .card:hover .card__title { color: var(--clay-deep); }
  .card__sub { font-size: 0.92rem; }
</style>
