---
import Base from '../../layouts/Base.astro';
import Figure from '../Figure.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { intro, site } from '../../data/site';
import { projects } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
const total = String(projects.length).padStart(2, '0');

const year = new Date().getFullYear();
const linkedin = site.social.find((s) => s.label === 'LinkedIn');
---

<Base lang={lang} altUrl={altUrl} chrome={false} title="" description={intro.lead[lang]}>
  <div class="cover">
    <!-- NAV superior: tres columnas ---------------------------------------- -->
    <nav class="cover__nav" aria-label="Principal">
      <a class="cover__navlink" href={url(lang)}>{t(lang, 'nav.projects')} 01–{total}</a>
      <a class="cover__navlink cover__navlink--center" href={url(lang, 'studio')}>{t(lang, 'nav.studio')}</a>
      <span class="cover__navright">
        <a class="cover__navlink" href={url(lang, 'contact')}>{t(lang, 'nav.contact')}</a>
        <a class="cover__lang" href={altUrl}>{t(lang, 'lang.switch')}</a>
      </span>
    </nav>

    <!-- FRISO de partículas: el nombre se descompone en cuadrados negros
         que se recomponen como geometrías, y vuelta a empezar -------------- -->
    <div class="band" aria-hidden="true">
      <canvas class="band__cv" data-band></canvas>
    </div>
    <h1 class="sr-only">{site.nameFull}</h1>

    <!-- TIRA horizontal de proyectos ---------------------------------------- -->
    <div class="stage">
      <span class="stage__scroll" aria-hidden="true">
        Scroll
        <svg width="44" height="10" viewBox="0 0 44 10" fill="none" aria-hidden="true">
          <path d="M0 5h41M36 1l6 4-6 4" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </span>
      <div class="strip" data-strip tabindex="0" aria-label={t(lang, 'projects.title')}>
        {projects.map((p) => (
          <a class="card" href={url(lang, 'projects', p.slug)} aria-label={p.title} data-strip-link>
            <Figure src={p.images[0]} alt={p.title} hue={p.hue} ratio="fill" loading="eager" class="card__fig" />
            <span class="card__plus" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
                <path d="M13 2v22M2 13h22" stroke="#fff" stroke-width="1.3" />
              </svg>
            </span>
            <span class="card__name">{p.title}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- BARRA inferior ------------------------------------------------------ -->
    <footer class="cover__foot">
      <a class="cover__navlink" href={`mailto:${site.email}`}>Email</a>
      {linkedin && (
        <a class="cover__navlink cover__navlink--center" href={linkedin.href} target="_blank" rel="noopener">
          LinkedIn
        </a>
      )}
      <span class="cover__copy">© {year}. Santiago de Pablo.</span>
    </footer>
  </div>
</Base>

<style>
  .cover {
    height: 100svh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    background: var(--bone);
    color: var(--ink);
    overflow: hidden;
  }

  /* NAV en tres columnas */
  .cover__nav,
  .cover__foot {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: clamp(1.1rem, 2.4vh, 1.8rem) var(--gutter);
  }
  .cover__navright { justify-self: end; display: inline-flex; align-items: center; gap: 1.2rem; }
  .cover__copy { justify-self: end; font-weight: 700; text-transform: uppercase; font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem); letter-spacing: 0.01em; }
  .cover__navlink {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem);
    letter-spacing: 0.01em;
    transition: opacity 0.3s var(--ease);
  }
  .cover__navlink:hover { opacity: 0.5; }
  .cover__navlink--center { justify-self: center; }
  .cover__lang {
    font-weight: 700; font-size: 0.8rem; letter-spacing: 0.06em;
    border: 1.5px solid var(--ink); border-radius: 100px; padding: 0.3em 0.75em;
    transition: background 0.3s var(--ease), color 0.3s var(--ease);
  }
  .cover__lang:hover { background: var(--ink); color: #fff; }

  /* FRISO de partículas: nombre ↔ geometrías, todo en negro */
  .band {
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    height: clamp(96px, 12vh, 136px);
    overflow: hidden;
    flex-shrink: 0;
  }
  .band__cv { display: block; width: 100%; height: 100%; }

  /* ESCENARIO con tira horizontal */
  .stage { position: relative; flex: 1; min-height: 0; display: flex; }
  .stage__scroll {
    position: absolute;
    left: var(--gutter);
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
    z-index: 2;
    pointer-events: none;
  }

  .strip {
    display: flex;
    align-items: center;
    gap: clamp(1.8rem, 2.6vw, 2.8rem);
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    /* Margen inicial amplio: reserva sitio al rótulo "Scroll →" */
    padding-inline: clamp(13rem, 15vw, 18rem) clamp(2.5rem, 5vw, 6rem);
    scrollbar-width: none;
    cursor: var(--cursor), grab;
    outline: none;
  }
  .strip::-webkit-scrollbar { display: none; }
  .strip.is-dragging { cursor: var(--cursor), grabbing; }
  .strip.is-dragging .card { pointer-events: none; }

  .card {
    position: relative;
    flex: 0 0 auto;
    height: min(82%, 780px);
    /* Ancho relativo a la pantalla: siempre entran ~4 proyectos a la vista */
    width: clamp(250px, 21vw, 480px);
    overflow: hidden;
    background: var(--sand);
  }
  .card :global(.card__fig) { position: absolute; inset: 0; height: 100%; }
  .card :global(.figure__img) { transition: transform 0.9s var(--ease); }
  .card:hover :global(.figure__img) { transform: scale(1.04); }

  /* El "+" aparece solo al pasar el ratón, discreto */
  .card__plus {
    position: absolute;
    top: 50%; left: 50%;
    translate: -50% -50%;
    width: clamp(48px, 4vw, 62px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(10, 10, 10, 0.85);
    display: grid;
    place-items: center;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .card__plus svg { width: 18px; height: 18px; }
  .card:hover .card__plus { opacity: 1; transform: scale(1); }
  @media (hover: none) { .card__plus { display: none; } }

  .card__name {
    position: absolute;
    left: 0; bottom: 0;
    right: 0;
    padding: 0.7rem 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .card:hover .card__name { opacity: 1; }

  .cover__foot { border-top: 2px solid var(--ink); }

  @media (max-width: 720px) {
    .cover__nav, .cover__foot { grid-template-columns: auto auto; justify-content: space-between; }
    .cover__navlink--center { display: none; }
    .stage__scroll { display: none; }
    .strip { padding-inline: var(--gutter); gap: 2rem; }
    .card { height: 68%; width: 74vw; }
  }
</style>

<script>
  const strip = document.querySelector<HTMLElement>('[data-strip]');
  if (strip) {
    // Rueda vertical → desplazamiento horizontal de la tira
    strip.closest('.stage')?.addEventListener(
      'wheel',
      (e) => {
        const ev = e as WheelEvent;
        const d = Math.abs(ev.deltaY) >= Math.abs(ev.deltaX) ? ev.deltaY : ev.deltaX;
        if (!d) return;
        e.preventDefault();
        strip.scrollLeft += d;
      },
      { passive: false }
    );

    // Arrastre con ratón. El puntero solo se captura cuando el movimiento
    // supera un umbral: así un clic limpio llega al enlace y abre el proyecto.
    // (En táctil se usa el scroll nativo.)
    let down = false, dragging = false, startX = 0, startLeft = 0, moved = 0, pid = 0;
    strip.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse' || e.button !== 0) return;
      down = true; dragging = false; moved = 0; pid = e.pointerId;
      startX = e.clientX; startLeft = strip.scrollLeft;
    });
    strip.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx));
      if (!dragging && Math.abs(dx) > 6) {
        dragging = true;
        strip.classList.add('is-dragging');
        try { strip.setPointerCapture(pid); } catch {}
      }
      if (dragging) strip.scrollLeft = startLeft - dx;
    });
    const release = () => {
      if (!down) return;
      down = false; dragging = false;
      strip.classList.remove('is-dragging');
      try { strip.releasePointerCapture(pid); } catch {}
    };
    strip.addEventListener('pointerup', release);
    strip.addEventListener('pointercancel', release);

    // Un arrastre no debe disparar el enlace; un clic limpio sí
    strip.addEventListener('click', (e) => {
      if (moved > 8) { e.preventDefault(); e.stopPropagation(); }
      moved = 0;
    }, true);

    // Teclado
    strip.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); strip.scrollBy({ left: 400, behavior: 'smooth' }); }
      if (e.key === 'ArrowLeft') { e.preventDefault(); strip.scrollBy({ left: -400, behavior: 'smooth' }); }
    });
  }
</script>

<script>
  // ── Friso de partículas ────────────────────────────────────────────────
  // El nombre del estudio, compuesto por cuadraditos negros, se descompone
  // y sus fragmentos se recolocan formando geometrías a toda altura. Bucle.
  const cv = document.querySelector<HTMLCanvasElement>('[data-band]');
  if (cv) {
    const ctx = cv.getContext('2d')!;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const TEXT = 'SANTIAGO DE PABLO ARQUITECTURA';

    type P = { fx: number; fy: number; tx: number; ty: number; sx: number; sy: number; dl: number };
    let pts: P[] = [];
    let W = 0, H = 0, t0 = 0;

    const setFont = (c: CanvasRenderingContext2D, h: number, w: number) => {
      let fs = h * 0.62;
      c.font = `800 ${fs}px 'Inter Variable', Inter, sans-serif`;
      const m = c.measureText(TEXT).width;
      if (m > w * 0.94) fs = (fs * w * 0.94) / m;
      c.font = `800 ${fs}px 'Inter Variable', Inter, sans-serif`;
      c.textAlign = 'center';
      c.textBaseline = 'middle';
    };

    const drawText = (c: CanvasRenderingContext2D, w: number, h: number) => {
      setFont(c, h, w);
      c.fillText(TEXT, w / 2, h / 2);
    };

    // Fila de geometrías a toda la altura de la franja
    const drawShapes = (c: CanvasRenderingContext2D, w: number, h: number) => {
      const s = h * 0.72;
      const cy = h / 2;
      const n = Math.max(4, Math.round(w / (s * 2.2)));
      const gap = w / n;
      const lw = Math.max(6, s * 0.18);
      for (let i = 0; i < n; i++) {
        const cx = gap * (i + 0.5);
        const k = i % 6;
        c.lineWidth = lw;
        if (k === 0) {
          c.beginPath(); c.arc(cx, cy, s / 2, 0, Math.PI * 2); c.fill();
        } else if (k === 1) {
          c.beginPath(); c.arc(cx, cy, s / 2 - lw / 2, 0, Math.PI * 2); c.stroke();
        } else if (k === 2) {
          c.beginPath(); c.moveTo(cx - s / 2, cy + s / 2); c.lineTo(cx + s / 2, cy + s / 2); c.lineTo(cx + s / 2, cy - s / 2); c.closePath(); c.fill();
        } else if (k === 3) {
          c.beginPath(); c.arc(cx, cy + s * 0.22, s / 2, Math.PI, 0); c.closePath(); c.fill();
        } else if (k === 4) {
          const q = s / Math.SQRT2;
          c.save(); c.translate(cx, cy); c.rotate(Math.PI / 4);
          c.strokeRect(-q / 2, -q / 2, q, q); c.restore();
        } else {
          const bw = s * 0.24;
          c.fillRect(cx - bw * 1.5, cy - s / 2, bw, s);
          c.fillRect(cx + bw * 0.5, cy - s / 2, bw, s);
        }
      }
    };

    // Muestrea los píxeles pintados y devuelve sus coordenadas
    const sample = (draw: (c: CanvasRenderingContext2D, w: number, h: number) => void) => {
      const off = document.createElement('canvas');
      off.width = W; off.height = H;
      const oc = off.getContext('2d')!;
      oc.fillStyle = '#000'; oc.strokeStyle = '#000';
      draw(oc, W, H);
      const data = oc.getImageData(0, 0, W, H).data;
      const collect = (s: number) => {
        const arr: [number, number][] = [];
        for (let y = 2; y < H; y += s)
          for (let x = 2; x < W; x += s)
            if (data[(y * W + x) * 4 + 3] > 128) arr.push([x, y]);
        return arr;
      };
      let step = 4;
      let out = collect(step);
      while (out.length > 3200 && step < 9) { step++; out = collect(step); }
      return out;
    };

    const build = () => {
      const r = cv.getBoundingClientRect();
      W = Math.max(1, Math.round(r.width));
      H = Math.max(1, Math.round(r.height));
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      cv.width = W * dpr; cv.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const a = sample(drawText);
      const b = sample(drawShapes);
      if (!a.length || !b.length) return;
      const n = Math.max(a.length, b.length);
      pts = Array.from({ length: n }, (_, i) => {
        const f = a[i % a.length];
        const t = b[(i * 7 + 3) % b.length]; // baraja el destino: la disolución se reparte
        const ang = Math.random() * Math.PI * 2;
        const amp = 24 + Math.random() * 46;
        return {
          fx: f[0], fy: f[1], tx: t[0], ty: t[1],
          sx: Math.cos(ang) * amp, sy: Math.sin(ang) * amp,
          dl: Math.random() * 0.3,
        };
      });
    };

    const ease = (x: number) => (x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2);

    // Ciclo: nombre 3s → disolución 2.6s → geometrías 3s → recomposición 2.6s
    const T1 = 3, T2 = 2.6, T3 = 3, T4 = 2.6, TT = T1 + T2 + T3 + T4;

    const frame = (now: number) => {
      if (!t0) t0 = now;
      const t = ((now - t0) / 1000) % TT;
      let p = 0;
      if (t < T1) p = 0;
      else if (t < T1 + T2) p = (t - T1) / T2;
      else if (t < T1 + T2 + T3) p = 1;
      else p = 1 - (t - T1 - T2 - T3) / T4;

      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = '#111';
      for (const q of pts) {
        const e = ease(Math.min(1, Math.max(0, (p - q.dl * 0.3) / 0.7)));
        const wob = Math.sin(Math.PI * e); // desvío en pleno vuelo
        const x = q.fx + (q.tx - q.fx) * e + q.sx * wob;
        const y = q.fy + (q.ty - q.fy) * e + q.sy * wob;
        ctx.fillRect(x - 1.6, y - 1.6, 3.2, 3.2);
      }
      requestAnimationFrame(frame);
    };

    const start = () => {
      build();
      if (reduce) {
        // Sin animación: solo el nombre, quieto
        ctx.clearRect(0, 0, W, H);
        ctx.fillStyle = '#111';
        for (const q of pts) ctx.fillRect(q.fx - 1.6, q.fy - 1.6, 3.2, 3.2);
        return;
      }
      requestAnimationFrame(frame);
    };

    let rto = 0;
    window.addEventListener('resize', () => {
      clearTimeout(rto);
      rto = window.setTimeout(build, 200);
    });

    if (document.fonts?.ready) document.fonts.ready.then(start);
    else start();
  }
</script>
