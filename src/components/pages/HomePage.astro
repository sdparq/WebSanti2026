---
import Base from '../../layouts/Base.astro';
import Figure from '../Figure.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { intro, site } from '../../data/site';
import { projects } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
const total = String(projects.length).padStart(2, '0');

const year = new Date().getFullYear();
const linkedin = site.social.find((s) => s.label === 'LinkedIn');
---

<Base lang={lang} altUrl={altUrl} chrome={false} title="" description={intro.lead[lang]}>
  <div class="cover">
    <!-- NAV superior: tres columnas ---------------------------------------- -->
    <nav class="cover__nav" aria-label="Principal">
      <a class="cover__navlink" href={url(lang)}>{t(lang, 'nav.projects')} 01–{total}</a>
      <a class="cover__navlink cover__navlink--center" href={url(lang, 'studio')}>{t(lang, 'nav.studio')}</a>
      <span class="cover__navright">
        <a class="cover__navlink" href={url(lang, 'contact')}>{t(lang, 'nav.contact')}</a>
        <a class="cover__lang" href={altUrl}>{t(lang, 'lang.switch')}</a>
      </span>
    </nav>

    <!-- BANDA animada: un proyecto esquemático que se dibuja y construye ----- -->
    <div class="band" aria-hidden="true">
      <svg viewBox="0 0 1600 110" preserveAspectRatio="xMidYMax slice">
        <!-- línea de suelo -->
        <line class="draw d0" x1="0" y1="96" x2="1600" y2="96" pathLength="100" />

        <!-- brújula / sol girando -->
        <g class="compass">
          <circle cx="150" cy="36" r="20" pathLength="100" stroke-dasharray="4 6" />
          <line x1="150" y1="36" x2="164" y2="22" />
        </g>

        <!-- casa con hastial que se traza sola -->
        <path class="draw d1" d="M60 96 V58 L96 34 L132 58 V96" pathLength="100" />
        <rect class="pop p1" x="78" y="66" width="12" height="12" />
        <rect class="pop p2" x="104" y="70" width="14" height="26" />

        <!-- edificio que crece planta a planta -->
        <g class="grow g1">
          <rect x="300" y="30" width="92" height="66" />
          <line x1="300" y1="41" x2="392" y2="41" />
          <line x1="300" y1="52" x2="392" y2="52" />
          <line x1="300" y1="63" x2="392" y2="63" />
          <line x1="300" y1="74" x2="392" y2="74" />
          <line x1="300" y1="85" x2="392" y2="85" />
        </g>
        <!-- cota de medición -->
        <path class="draw d2" d="M300 100 v8 M300 104 H392 M392 100 v8" pathLength="100" />

        <!-- grúa: mástil, pluma que gira y gancho que iza -->
        <line class="draw d3" x1="560" y1="96" x2="560" y2="16" pathLength="100" />
        <g class="jib">
          <path d="M516 18 H668 M560 18 V5 M560 5 L644 18 M560 5 L526 18" />
          <g class="hook">
            <line x1="644" y1="18" x2="644" y2="50" />
            <rect x="637" y="50" width="14" height="12" />
          </g>
        </g>

        <!-- edificio de bloques que la grúa va apilando -->
        <rect class="stack s1" x="604" y="80" width="72" height="16" />
        <rect class="stack s2" x="604" y="63" width="72" height="16" />
        <rect class="stack s3" x="604" y="46" width="72" height="16" />

        <!-- torre con antena -->
        <g class="grow g2">
          <rect x="880" y="24" width="66" height="72" />
          <line x1="880" y1="42" x2="946" y2="42" />
          <line x1="880" y1="60" x2="946" y2="60" />
          <line x1="880" y1="78" x2="946" y2="78" />
        </g>
        <line class="draw d4" x1="913" y1="24" x2="913" y2="8" pathLength="100" />

        <!-- bóveda -->
        <path class="draw d5" d="M1000 96 A46 46 0 0 1 1092 96" pathLength="100" />

        <!-- edificio escalonado -->
        <path class="draw d6" d="M1180 96 V64 H1222 V44 H1264 V24 H1306 V96" pathLength="100" />
        <rect class="pop p3" x="1192" y="74" width="12" height="12" />
        <rect class="pop p4" x="1234" y="54" width="12" height="12" />
        <rect class="pop p5" x="1276" y="34" width="12" height="12" />

        <!-- árboles que se mecen -->
        <g class="tree t1">
          <line x1="1370" y1="96" x2="1370" y2="78" />
          <circle cx="1370" cy="68" r="11" />
        </g>
        <g class="tree t2">
          <line x1="1408" y1="96" x2="1408" y2="82" />
          <circle cx="1408" cy="74" r="8" />
        </g>

        <!-- pabellón: pilares que crecen y losa que aterriza -->
        <g class="grow g3">
          <line x1="1478" y1="96" x2="1478" y2="52" />
          <line x1="1510" y1="96" x2="1510" y2="52" />
          <line x1="1542" y1="96" x2="1542" y2="52" />
          <line x1="1574" y1="96" x2="1574" y2="52" />
        </g>
        <rect class="slab" x="1466" y="44" width="120" height="8" />
      </svg>
    </div>
    <h1 class="sr-only">{site.nameFull}</h1>

    <!-- TIRA horizontal de proyectos ---------------------------------------- -->
    <div class="stage">
      <span class="stage__scroll" aria-hidden="true">
        Scroll
        <svg width="44" height="10" viewBox="0 0 44 10" fill="none" aria-hidden="true">
          <path d="M0 5h41M36 1l6 4-6 4" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </span>
      <div class="strip" data-strip tabindex="0" aria-label={t(lang, 'projects.title')}>
        {projects.map((p) => (
          <a class="card" href={url(lang, 'projects', p.slug)} aria-label={p.title} data-strip-link>
            <Figure src={p.images[0]} alt={p.title} hue={p.hue} ratio="fill" loading="eager" class="card__fig" />
            <span class="card__plus" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
                <path d="M13 2v22M2 13h22" stroke="#fff" stroke-width="1.3" />
              </svg>
            </span>
            <span class="card__name">{p.title}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- BARRA inferior ------------------------------------------------------ -->
    <footer class="cover__foot">
      <a class="cover__navlink" href={`mailto:${site.email}`}>Email</a>
      {linkedin && (
        <a class="cover__navlink cover__navlink--center" href={linkedin.href} target="_blank" rel="noopener">
          LinkedIn
        </a>
      )}
      <span class="cover__copy">© {year}. Santiago de Pablo.</span>
    </footer>
  </div>
</Base>

<style>
  .cover {
    height: 100svh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    background: var(--bone);
    color: var(--ink);
    overflow: hidden;
  }

  /* NAV en tres columnas */
  .cover__nav,
  .cover__foot {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: clamp(1.1rem, 2.4vh, 1.8rem) var(--gutter);
  }
  .cover__navright { justify-self: end; display: inline-flex; align-items: center; gap: 1.2rem; }
  .cover__copy { justify-self: end; font-weight: 700; text-transform: uppercase; font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem); letter-spacing: 0.01em; }
  .cover__navlink {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem);
    letter-spacing: 0.01em;
    transition: opacity 0.3s var(--ease);
  }
  .cover__navlink:hover { opacity: 0.5; }
  .cover__navlink--center { justify-self: center; }
  .cover__lang {
    font-weight: 700; font-size: 0.8rem; letter-spacing: 0.06em;
    border: 1.5px solid var(--ink); border-radius: 100px; padding: 0.3em 0.75em;
    transition: background 0.3s var(--ease), color 0.3s var(--ease);
  }
  .cover__lang:hover { background: var(--ink); color: #fff; }

  /* BANDA animada: proyecto esquemático en construcción permanente */
  .band {
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    height: clamp(84px, 11vh, 120px);
    overflow: hidden;
    flex-shrink: 0;
  }
  .band svg { width: 100%; height: 100%; display: block; }
  .band :is(path, line, rect, circle) {
    stroke: var(--ink);
    stroke-width: 2;
    fill: none;
    stroke-linecap: square;
  }
  .band .pop { fill: var(--ink); stroke: none; }
  .band .stack, .band .slab { fill: var(--bone); }

  /* trazos que se dibujan y borran en bucle */
  .draw { stroke-dasharray: 100; animation: bandDraw 14s ease-in-out infinite; }
  .d0 { animation-delay: 0s; }
  .d1 { animation-delay: 0.3s; }
  .d2 { animation-delay: 0.9s; }
  .d3 { animation-delay: 0.5s; }
  .d4 { animation-delay: 1.6s; }
  .d5 { animation-delay: 0.7s; }
  .d6 { animation-delay: 0.4s; }
  @keyframes bandDraw {
    0% { stroke-dashoffset: 100; }
    20% { stroke-dashoffset: 0; }
    86% { stroke-dashoffset: 0; }
    96%, 100% { stroke-dashoffset: 100; }
  }

  /* edificios que crecen planta a planta (escalones) */
  .grow {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: bandGrow 14s infinite;
  }
  .g1 { animation-delay: 0.6s; }
  .g2 { animation-delay: 1.1s; }
  .g3 { animation-delay: 1.5s; }
  @keyframes bandGrow {
    0% { transform: scaleY(0); animation-timing-function: steps(6, end); }
    24% { transform: scaleY(1); }
    88% { transform: scaleY(1); animation-timing-function: steps(6, end); }
    97%, 100% { transform: scaleY(0); }
  }

  /* ventanas y puertas que aparecen */
  .pop { animation: bandPop 14s infinite; }
  .p1 { animation-delay: 0.2s; }
  .p2 { animation-delay: 0.5s; }
  .p3 { animation-delay: 0.7s; }
  .p4 { animation-delay: 1s; }
  .p5 { animation-delay: 1.3s; }
  @keyframes bandPop {
    0%, 24% { opacity: 0; }
    30%, 84% { opacity: 1; }
    92%, 100% { opacity: 0; }
  }

  /* bloques que la grúa apila */
  .stack { transform-box: fill-box; animation: bandStack 14s infinite; }
  .s1 { animation-delay: 0.4s; }
  .s2 { animation-delay: 1.3s; }
  .s3 { animation-delay: 2.2s; }
  @keyframes bandStack {
    0%, 8% { opacity: 0; transform: translateY(-26px); }
    16% { opacity: 1; transform: translateY(0); }
    86% { opacity: 1; transform: translateY(0); }
    93%, 100% { opacity: 0; transform: translateY(-26px); }
  }

  /* grúa: pluma que gira y gancho que iza */
  .jib { transform-origin: 560px 18px; animation: bandSway 6s ease-in-out infinite alternate; }
  .hook { animation: bandHoist 5s ease-in-out infinite; }
  @keyframes bandSway { from { transform: rotate(-5deg); } to { transform: rotate(5deg); } }
  @keyframes bandHoist { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(16px); } }

  /* losa del pabellón que aterriza sobre los pilares */
  .slab { transform-box: fill-box; animation: bandStack 14s infinite; animation-delay: 2.6s; }

  /* brújula girando y árboles meciéndose */
  .compass { transform-origin: 150px 36px; animation: bandSpin 26s linear infinite; }
  @keyframes bandSpin { to { transform: rotate(360deg); } }
  .tree { transform-box: fill-box; transform-origin: 50% 100%; animation: bandSway 4s ease-in-out infinite alternate; }
  .t2 { animation-duration: 5s; }

  @media (prefers-reduced-motion: reduce) {
    .band * { animation: none !important; }
    .draw { stroke-dasharray: none; }
  }

  /* ESCENARIO con tira horizontal */
  .stage { position: relative; flex: 1; min-height: 0; display: flex; }
  .stage__scroll {
    position: absolute;
    left: var(--gutter);
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
    z-index: 2;
    pointer-events: none;
  }

  .strip {
    display: flex;
    align-items: center;
    gap: clamp(1.8rem, 2.6vw, 2.8rem);
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    /* Margen inicial amplio: reserva sitio al rótulo "Scroll →" */
    padding-inline: clamp(13rem, 15vw, 18rem) clamp(2.5rem, 5vw, 6rem);
    scrollbar-width: none;
    cursor: grab;
    outline: none;
  }
  .strip::-webkit-scrollbar { display: none; }
  .strip.is-dragging { cursor: grabbing; }
  .strip.is-dragging .card { pointer-events: none; }

  .card {
    position: relative;
    flex: 0 0 auto;
    height: min(82%, 780px);
    /* Ancho relativo a la pantalla: siempre entran ~4 proyectos a la vista */
    width: clamp(250px, 21vw, 480px);
    overflow: hidden;
    background: var(--sand);
  }
  .card :global(.card__fig) { position: absolute; inset: 0; height: 100%; }
  .card :global(.figure__img) { transition: transform 0.9s var(--ease); }
  .card:hover :global(.figure__img) { transform: scale(1.04); }

  /* El "+" aparece solo al pasar el ratón, discreto */
  .card__plus {
    position: absolute;
    top: 50%; left: 50%;
    translate: -50% -50%;
    width: clamp(48px, 4vw, 62px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(10, 10, 10, 0.85);
    display: grid;
    place-items: center;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .card__plus svg { width: 18px; height: 18px; }
  .card:hover .card__plus { opacity: 1; transform: scale(1); }
  @media (hover: none) { .card__plus { display: none; } }

  .card__name {
    position: absolute;
    left: 0; bottom: 0;
    right: 0;
    padding: 0.7rem 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .card:hover .card__name { opacity: 1; }

  .cover__foot { border-top: 2px solid var(--ink); }

  @media (max-width: 720px) {
    .cover__nav, .cover__foot { grid-template-columns: auto auto; justify-content: space-between; }
    .cover__navlink--center { display: none; }
    .stage__scroll { display: none; }
    .strip { padding-inline: var(--gutter); gap: 2rem; }
    .card { height: 68%; width: 74vw; }
  }
</style>

<script>
  const strip = document.querySelector<HTMLElement>('[data-strip]');
  if (strip) {
    // Rueda vertical → desplazamiento horizontal de la tira
    strip.closest('.stage')?.addEventListener(
      'wheel',
      (e) => {
        const ev = e as WheelEvent;
        const d = Math.abs(ev.deltaY) >= Math.abs(ev.deltaX) ? ev.deltaY : ev.deltaX;
        if (!d) return;
        e.preventDefault();
        strip.scrollLeft += d;
      },
      { passive: false }
    );

    // Arrastre con ratón. El puntero solo se captura cuando el movimiento
    // supera un umbral: así un clic limpio llega al enlace y abre el proyecto.
    // (En táctil se usa el scroll nativo.)
    let down = false, dragging = false, startX = 0, startLeft = 0, moved = 0, pid = 0;
    strip.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse' || e.button !== 0) return;
      down = true; dragging = false; moved = 0; pid = e.pointerId;
      startX = e.clientX; startLeft = strip.scrollLeft;
    });
    strip.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx));
      if (!dragging && Math.abs(dx) > 6) {
        dragging = true;
        strip.classList.add('is-dragging');
        try { strip.setPointerCapture(pid); } catch {}
      }
      if (dragging) strip.scrollLeft = startLeft - dx;
    });
    const release = () => {
      if (!down) return;
      down = false; dragging = false;
      strip.classList.remove('is-dragging');
      try { strip.releasePointerCapture(pid); } catch {}
    };
    strip.addEventListener('pointerup', release);
    strip.addEventListener('pointercancel', release);

    // Un arrastre no debe disparar el enlace; un clic limpio sí
    strip.addEventListener('click', (e) => {
      if (moved > 8) { e.preventDefault(); e.stopPropagation(); }
      moved = 0;
    }, true);

    // Teclado
    strip.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); strip.scrollBy({ left: 400, behavior: 'smooth' }); }
      if (e.key === 'ArrowLeft') { e.preventDefault(); strip.scrollBy({ left: -400, behavior: 'smooth' }); }
    });
  }
</script>
