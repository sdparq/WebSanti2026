---
import Base from '../../layouts/Base.astro';
import Figure from '../Figure.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { projects } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
---

<Base lang={lang} altUrl={altUrl} title={t(lang, 'projects.title')} description={t(lang, 'projects.intro')}>
  <section class="page-head container">
    <p class="eyebrow" data-reveal>{t(lang, 'projects.title')}</p>
    <h1 class="display" data-reveal>{t(lang, 'projects.title')}</h1>
    <p class="lead muted" data-reveal style="max-width:42ch;margin-top:1.5rem;">{t(lang, 'projects.intro')}</p>
  </section>

  <section class="plist">
    {projects.map((p, i) => (
        <a class="prow" href={url(lang, 'projects', p.slug)} data-reveal>
          <div class="prow__media" data-parallax>
            <Figure src={p.images[0]} alt={p.title} hue={p.hue} ratio="fill" zoom={true} />
          </div>
          <div class="prow__scrim"></div>
          <div class="prow__content container">
            <span class="prow__index">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="prow__title">{p.title}</h2>
            <p class="prow__meta">
              <span>{p.location[lang]}</span>
              <span class="prow__dot">·</span>
              <span>{p.category[lang]}</span>
              {p.award && <span class="prow__dot">·</span>}
              {p.award && <span class="prow__award">{p.award[lang]}</span>}
              {p.year && <span class="prow__dot">·</span>}
              {p.year && <span>{p.year}</span>}
            </p>
          </div>
        </a>
    ))}
  </section>
</Base>

<style>
  .page-head { padding-top: clamp(7rem, 16vh, 12rem); padding-bottom: clamp(2.5rem, 6vw, 5rem); }
  .plist { display: flex; flex-direction: column; }
  .prow {
    position: relative; display: flex; align-items: flex-end;
    height: clamp(420px, 78vh, 820px); overflow: hidden; color: #fff;
  }
  .prow__media { position: absolute; inset: -10% 0; }
  .prow__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,11,8,0.72) 0%, rgba(15,11,8,0.08) 50%, rgba(15,11,8,0.2) 100%);
  }
  .prow__content { position: relative; width: 100%; padding-bottom: clamp(2.5rem, 6vh, 5rem); }
  .prow__index { font-size: 0.8rem; letter-spacing: 0.18em; color: rgba(255,255,255,0.7); }
  .prow__title {
    color: #fff; font-weight: 750; text-transform: uppercase; margin: 0.6rem 0 0.6rem;
    font-size: clamp(2rem, 1rem + 5vw, 6rem); line-height: 0.98; letter-spacing: -0.025em;
    text-shadow: 0 4px 50px rgba(0,0,0,0.35);
  }
  .prow__meta { display: flex; flex-wrap: wrap; gap: 0.55rem; color: rgba(255,255,255,0.88); font-size: clamp(0.92rem, 0.9rem + 0.2vw, 1.1rem); }
  .prow__dot { opacity: 0.5; }
  .prow__award { color: #e9c89a; letter-spacing: 0.02em; }
</style>

<script>
  const layers = Array.from(document.querySelectorAll('[data-parallax]')) as HTMLElement[];
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let ticking = false;
  function update() {
    const vh = window.innerHeight;
    for (const el of layers) {
      const parent = el.parentElement as HTMLElement;
      const rect = parent.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > vh) continue;
      const progress = (rect.top + rect.height / 2 - vh / 2) / vh;
      el.style.transform = `translate3d(0, ${progress * 10}%, 0)`;
    }
    ticking = false;
  }
  function onScroll() { if (!ticking && !reduce) { ticking = true; requestAnimationFrame(update); } }
  if (!reduce) { update(); window.addEventListener('scroll', onScroll, { passive: true }); window.addEventListener('resize', onScroll, { passive: true }); }
</script>
