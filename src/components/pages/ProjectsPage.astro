---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../ProjectCard.astro';
import { type Lang, t } from '../../i18n/ui';
import { projects } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
---

<Base lang={lang} altUrl={altUrl} title={t(lang, 'projects.title')} description={t(lang, 'projects.intro')}>
  <section class="page-head container">
    <p class="eyebrow" data-reveal>{t(lang, 'projects.title')}</p>
    <h1 class="display" data-reveal>{t(lang, 'projects.title')}</h1>
    <p class="lead muted" data-reveal style="max-width:42ch;margin-top:1.5rem;">{t(lang, 'projects.intro')}</p>
  </section>

  <section class="container section--tight">
    <div class="projects-grid">
      {projects.map((p, i) => (
        <ProjectCard project={p} lang={lang} index={i} ratio="4 / 3" />
      ))}
    </div>
  </section>
</Base>

<style>
  .page-head { padding-top: clamp(7rem, 16vh, 12rem); padding-bottom: clamp(1.5rem, 4vw, 3rem); }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 5vw, 5rem) clamp(1.5rem, 3vw, 3rem);
  }
  @media (max-width: 720px) { .projects-grid { grid-template-columns: 1fr; } }
</style>
