---
import Base from '../../layouts/Base.astro';
import VillaProcess from '../VillaProcess.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { about, services } from '../../data/site';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
---

<Base lang={lang} altUrl={altUrl} title={about.title[lang]} description={about.paragraphs[lang][0]}>
  <section class="page-head container">
    <p class="eyebrow" data-reveal>{about.title[lang]}</p>
    <h1 class="display" data-reveal>{about.title[lang]}</h1>
  </section>

  <section class="container studio-intro">
    <div class="studio-text">
      {about.paragraphs[lang].map((para, i) => (
        <p class:list={[{ lead: i === 0 }]} data-reveal>{para}</p>
      ))}
    </div>
    <div class="studio-portrait" data-reveal>
      <VillaProcess lang={lang} />
    </div>
  </section>

  <section class="section container">
    <h2 class="eyebrow" data-reveal>{services.title[lang]}</h2>
    <div class="studio-services">
      {services.items.map((s, i) => (
        <div class="studio-service" data-reveal data-reveal-delay={i % 3}>
          <span class="studio-service__num">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="h-md">{s.title[lang]}</h3>
          <p class="muted">{s.text[lang]}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container section--tight">
    <a class="btn btn--solid" href={url(lang, 'contact')}>{t(lang, 'cta.contact')} <span class="arrow">→</span></a>
  </section>
</Base>

<style>
  .page-head { padding-top: clamp(7rem, 16vh, 12rem); padding-bottom: clamp(1.5rem, 4vw, 3rem); }
  .studio-intro {
    display: grid; grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 6vw, 6rem); align-items: stretch;
  }
  .studio-text { display: grid; gap: 1.4rem; max-width: 58ch; align-content: start; }
  .studio-portrait { display: flex; flex-direction: column; }
  @media (max-width: 820px) {
    .studio-intro { grid-template-columns: 1fr; }
    .studio-portrait { max-width: 360px; }
  }

  .studio-services {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-top: clamp(1.5rem, 4vw, 3rem);
  }
  .studio-service { border-top: 1px solid var(--line); padding-top: 1.2rem; }
  .studio-service__num { font-size: 0.8rem; color: var(--clay-deep); letter-spacing: 0.1em; }
  .studio-service h3 { margin: 0.6rem 0; }
  @media (max-width: 600px) { .studio-services { grid-template-columns: 1fr; } }
</style>
