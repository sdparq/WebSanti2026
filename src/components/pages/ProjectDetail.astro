---
import Base from '../../layouts/Base.astro';
import Figure from '../Figure.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { site } from '../../data/site';
import { projects, type Project } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
  project: Project;
}
const { lang, altUrl, project: p } = Astro.props;

const idx = projects.findIndex((x) => x.slug === p.slug);
const next = projects[(idx + 1) % projects.length];
const total = String(projects.length).padStart(2, '0');
const year = new Date().getFullYear();
const instagram = site.social.find((s) => s.label === 'Instagram');

const meta: string[] = [
  p.location[lang],
  p.category[lang],
  p.award?.[lang],
  p.status?.[lang],
  p.area,
  p.year,
].filter(Boolean) as string[];
---

<Base lang={lang} altUrl={altUrl} chrome={false} title={p.title} description={p.summary[lang]}>
  <div class="cover">
    <!-- NAV superior -------------------------------------------------------- -->
    <nav class="cover__nav" aria-label="Principal">
      <a class="cover__navlink" href={url(lang)}>{t(lang, 'nav.projects')} {String(idx + 1).padStart(2, '0')}–{total}</a>
      <a class="cover__navlink cover__navlink--center" href={url(lang, 'studio')}>{t(lang, 'nav.studio')}</a>
      <span class="cover__navright">
        <a class="cover__navlink" href={url(lang, 'contact')}>{t(lang, 'nav.contact')}</a>
        <a class="cover__lang" href={altUrl}>{t(lang, 'lang.switch')}</a>
      </span>
    </nav>

    <!-- BANDA de título ------------------------------------------------------ -->
    <div class="titleband">
      <h1 class="titleband__title">{p.title}</h1>
    </div>

    <!-- TIRA horizontal: texto + imágenes ------------------------------------ -->
    <div class="stage">
      <div class="strip" data-strip tabindex="0">
        <div class="panel panel--text">
          {p.description[lang].map((par) => <p class="panel__par">{par}</p>)}
          <p class="panel__meta">{meta.join(' · ')}</p>
        </div>

        <span class="strip__hint" aria-hidden="true">
          Scroll
          <svg width="44" height="10" viewBox="0 0 44 10" fill="none" aria-hidden="true">
            <path d="M0 5h41M36 1l6 4-6 4" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </span>

        {p.images.length > 0
          ? p.images.map((src, i) => (
              <figure class="panel panel--img">
                <img src={src} alt={`${p.title} — ${i + 1}`} loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />
              </figure>
            ))
          : [0, 1].map((i) => (
              <figure class="panel panel--img panel--ph">
                <Figure src={undefined} alt={p.title} hue={(p.hue + i * 14) % 360} ratio="fill" />
              </figure>
            ))}

        <a class="panel panel--next" href={url(lang, 'projects', next.slug)}>
          <span class="panel__nextlabel">{t(lang, 'project.next')}</span>
          <strong class="panel__nexttitle">{next.title}</strong>
          <svg width="54" height="12" viewBox="0 0 54 12" fill="none" aria-hidden="true">
            <path d="M0 6h50M44 1l7 5-7 5" stroke="currentColor" stroke-width="1.4" />
          </svg>
        </a>
      </div>
    </div>

    <!-- BARRA inferior ------------------------------------------------------- -->
    <footer class="cover__foot">
      <a class="cover__navlink" href={`mailto:${site.email}`}>Email</a>
      {instagram && (
        <a class="cover__navlink cover__navlink--center" href={instagram.href} target="_blank" rel="noopener">
          Instagram
        </a>
      )}
      <span class="cover__copy">© {year}. Santiago de Pablo.</span>
    </footer>
  </div>
</Base>

<style>
  .cover {
    height: 100svh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    background: var(--bone);
    color: var(--ink);
    overflow: hidden;
  }

  .cover__nav,
  .cover__foot {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: clamp(1.1rem, 2.4vh, 1.8rem) var(--gutter);
  }
  .cover__navright { justify-self: end; display: inline-flex; align-items: center; gap: 1.2rem; }
  .cover__copy { justify-self: end; font-weight: 700; text-transform: uppercase; font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem); }
  .cover__navlink {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.95rem, 0.85rem + 0.3vw, 1.15rem);
    letter-spacing: 0.01em;
    transition: opacity 0.3s var(--ease);
  }
  .cover__navlink:hover { opacity: 0.5; }
  .cover__navlink--center { justify-self: center; }
  .cover__lang {
    font-weight: 700; font-size: 0.8rem; letter-spacing: 0.06em;
    border: 1.5px solid var(--ink); border-radius: 100px; padding: 0.3em 0.75em;
    transition: background 0.3s var(--ease), color 0.3s var(--ease);
  }
  .cover__lang:hover { background: var(--ink); color: #fff; }
  .cover__foot { border-top: 2px solid var(--ink); }

  /* Banda de título */
  .titleband {
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    padding: 0.05em var(--gutter);
    flex-shrink: 0;
    overflow: hidden;
  }
  .titleband__title {
    font-weight: 780;
    text-transform: uppercase;
    font-size: clamp(2.4rem, 1rem + 5.5vw, 6.2rem);
    line-height: 1.14;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  /* Tira horizontal */
  .stage { flex: 1; min-height: 0; display: flex; }
  .strip {
    display: flex;
    align-items: center;
    gap: clamp(3rem, 7vw, 8rem);
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding-inline: var(--gutter) clamp(3rem, 8vw, 9rem);
    scrollbar-width: none;
    cursor: grab;
    outline: none;
  }
  .strip::-webkit-scrollbar { display: none; }
  .strip.is-dragging { cursor: grabbing; }
  .strip.is-dragging a { pointer-events: none; }

  .panel { flex: 0 0 auto; }

  /* Panel de texto (primer elemento): columna estrecha, centrada y alineada */
  .panel--text {
    width: min(46ch, 60vw);
    margin-left: clamp(2rem, 9vw, 11rem);
  }
  .panel__par {
    font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.1rem);
    line-height: 1.62;
    margin-bottom: 1em;
    text-align: left;
    text-wrap: pretty;
  }
  .panel__par:first-child { text-indent: 3ch; }
  .panel__meta {
    margin-top: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }

  .strip__hint {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
  }

  /* Paneles de imagen: grandes, respetando su proporción */
  .panel--img {
    height: min(86%, 720px);
    background: var(--sand);
  }
  .panel--img img {
    height: 100%;
    width: auto;
    max-width: none;
    display: block;
  }
  .panel--ph { position: relative; aspect-ratio: 4 / 3; }

  /* Panel final: siguiente proyecto */
  .panel--next {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-right: clamp(2rem, 6vw, 6rem);
  }
  .panel__nextlabel {
    font-weight: 700; text-transform: uppercase;
    font-size: 0.82rem; letter-spacing: 0.08em; color: var(--ink-soft);
  }
  .panel__nexttitle {
    font-weight: 780; text-transform: uppercase;
    font-size: clamp(1.8rem, 1rem + 2.6vw, 3.6rem);
    line-height: 1; letter-spacing: -0.01em;
    max-width: 14ch;
  }
  .panel--next svg { transition: transform 0.4s var(--ease); }
  .panel--next:hover svg { transform: translateX(8px); }

  @media (max-width: 720px) {
    .cover__nav, .cover__foot { grid-template-columns: auto auto; justify-content: space-between; }
    .cover__navlink--center { display: none; }
    .titleband__title { white-space: normal; font-size: clamp(2rem, 1rem + 6vw, 3.4rem); }
    .panel--text { width: 82vw; padding-left: 0; }
    .panel--img { height: 62%; }
  }
</style>

<script>
  const strip = document.querySelector<HTMLElement>('[data-strip]');
  if (strip) {
    // Rueda vertical → desplazamiento horizontal
    strip.closest('.stage')?.addEventListener(
      'wheel',
      (e) => {
        const ev = e as WheelEvent;
        const d = Math.abs(ev.deltaY) >= Math.abs(ev.deltaX) ? ev.deltaY : ev.deltaX;
        if (!d) return;
        e.preventDefault();
        strip.scrollLeft += d;
      },
      { passive: false }
    );

    // Arrastre con ratón. El puntero solo se captura al superar un umbral,
    // para que un clic limpio llegue al enlace. (En táctil, scroll nativo.)
    let down = false, dragging = false, startX = 0, startLeft = 0, moved = 0, pid = 0;
    strip.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse' || e.button !== 0) return;
      down = true; dragging = false; moved = 0; pid = e.pointerId;
      startX = e.clientX; startLeft = strip.scrollLeft;
    });
    strip.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx));
      if (!dragging && Math.abs(dx) > 6) {
        dragging = true;
        strip.classList.add('is-dragging');
        try { strip.setPointerCapture(pid); } catch {}
      }
      if (dragging) strip.scrollLeft = startLeft - dx;
    });
    const release = () => {
      if (!down) return;
      down = false; dragging = false;
      strip.classList.remove('is-dragging');
      try { strip.releasePointerCapture(pid); } catch {}
    };
    strip.addEventListener('pointerup', release);
    strip.addEventListener('pointercancel', release);
    strip.addEventListener('click', (e) => {
      if (moved > 8) { e.preventDefault(); e.stopPropagation(); }
      moved = 0;
    }, true);

    // Teclado
    strip.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); strip.scrollBy({ left: 420, behavior: 'smooth' }); }
      if (e.key === 'ArrowLeft') { e.preventDefault(); strip.scrollBy({ left: -420, behavior: 'smooth' }); }
    });
  }
</script>
