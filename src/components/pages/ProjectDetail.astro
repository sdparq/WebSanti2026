---
import Base from '../../layouts/Base.astro';
import Figure from '../Figure.astro';
import { type Lang, t, url } from '../../i18n/ui';
import { projects, type Project } from '../../data/projects';

interface Props {
  lang: Lang;
  altUrl: string;
  project: Project;
}
const { lang, altUrl, project: p } = Astro.props;

const idx = projects.findIndex((x) => x.slug === p.slug);
const next = projects[(idx + 1) % projects.length];

const info: { label: string; value?: string }[] = [
  { label: t(lang, 'project.location'), value: p.location[lang] },
  { label: t(lang, 'project.year'), value: p.year },
  { label: t(lang, 'project.category'), value: p.category[lang] },
  { label: t(lang, 'project.status'), value: p.status?.[lang] },
  { label: t(lang, 'project.area'), value: p.area },
];

// Si no hay imágenes reales, generamos varios placeholders para componer la galería.
const gallery = p.images.length > 0 ? p.images : [undefined, undefined, undefined, undefined];
---

<Base lang={lang} altUrl={altUrl} dark={true} title={p.title} description={p.summary[lang]}>
  <article class="project">
    <!-- Portada -->
    <header class="project__hero">
      <Figure
        src={p.images[0]}
        alt={p.title}
        label={p.images[0] ? undefined : p.title}
        hue={p.hue}
        ratio="16 / 9"
        loading="eager"
        class="project__cover"
      />
    </header>

    <!-- Cabecera de texto -->
    <section class="container project__intro">
      <div class="project__intro-main">
        <a class="link-underline back" href={url(lang, 'projects')}>← {t(lang, 'project.back')}</a>
        <h1 class="display" data-reveal>{p.title}</h1>
        <p class="lead" data-reveal style="max-width:36ch;margin-top:1.5rem;">{p.summary[lang]}</p>
      </div>
      <aside class="project__info" data-reveal>
        <h2 class="eyebrow">{t(lang, 'project.info')}</h2>
        <dl>
          {info.filter((i) => i.value).map((i) => (
            <div class="info-row">
              <dt class="muted">{i.label}</dt>
              <dd>{i.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </section>

    <!-- Cuerpo de texto + galería intercalada -->
    <section class="container project__body">
      <div class="project__text">
        {p.description[lang].map((para) => (
          <p data-reveal>{para}</p>
        ))}
      </div>
    </section>

    <section class="container project__gallery">
      {gallery.map((src, i) => (
        <Figure
          src={src}
          alt={`${p.title} — ${i + 1}`}
          label={src ? undefined : p.title}
          hue={(p.hue + i * 12) % 360}
          ratio={i % 3 === 0 ? '16 / 9' : '4 / 3'}
          class={i % 3 === 0 ? 'gal-wide' : 'gal-item'}
        />
      ))}
    </section>

    <!-- Siguiente proyecto -->
    <a class="project__next" href={url(lang, 'projects', next.slug)}>
      <div class="container project__next-inner">
        <span class="eyebrow">{t(lang, 'project.next')}</span>
        <span class="project__next-title">{next.title} <span class="arrow">→</span></span>
      </div>
    </a>
  </article>
</Base>

<style>
  .project__hero { padding-top: 0; }
  .project :global(.project__cover) { aspect-ratio: 16 / 9; }
  @media (min-width: 1024px) { .project :global(.project__cover) { aspect-ratio: 21 / 9; } }

  .project__intro {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    padding-top: clamp(3rem, 7vw, 6rem);
  }
  .back { display: inline-block; margin-bottom: 1.5rem; font-size: 0.95rem; }
  .project__info dl { margin-top: 1rem; }
  .info-row {
    display: flex; justify-content: space-between; gap: 1rem;
    padding: 0.8rem 0; border-top: 1px solid var(--line);
  }
  .info-row dd { text-align: right; }

  .project__body { padding-top: clamp(3rem, 7vw, 6rem); }
  .project__text {
    max-width: 62ch;
    margin-inline: auto;
    display: grid; gap: 1.4rem;
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
    line-height: 1.65;
  }

  .project__gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
    padding-top: clamp(3rem, 7vw, 6rem);
  }
  .project__gallery :global(.gal-wide) { grid-column: 1 / -1; }
  @media (max-width: 640px) {
    .project__gallery { grid-template-columns: 1fr; }
    .project__gallery :global(.gal-wide) { grid-column: auto; }
  }

  .project__intro { } /* placeholder */
  @media (max-width: 820px) {
    .project__intro { grid-template-columns: 1fr; }
    .info-row dd { text-align: right; }
  }

  .project__next {
    display: block;
    margin-top: clamp(4rem, 9vw, 8rem);
    background: var(--ink);
    color: var(--bone);
    padding-block: clamp(3rem, 8vw, 7rem);
    transition: background 0.5s var(--ease);
  }
  .project__next:hover { background: #1c1813; }
  .project__next-inner { display: flex; flex-direction: column; gap: 0.8rem; }
  .project__next .eyebrow { color: var(--sand); }
  .project__next-title {
    font-family: var(--font-serif); font-weight: 350;
    font-size: clamp(2rem, 1.2rem + 4vw, 5rem); line-height: 1;
  }
</style>
