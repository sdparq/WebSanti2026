---
import { type Lang, t, url, otherLang } from '../i18n/ui';
import { site } from '../data/site';

interface Props {
  lang: Lang;
  altUrl: string; // misma página en el otro idioma
}
const { lang, altUrl } = Astro.props;
const other = otherLang(lang);

const nav = [
  { key: 'nav.projects', href: url(lang, 'projects') },
  { key: 'nav.studio', href: url(lang, 'studio') },
  { key: 'nav.contact', href: url(lang, 'contact') },
] as const;
---

<header class="site-header" data-header>
  <div class="site-header__inner container">
    <a class="brand" href={url(lang)} aria-label={site.nameFull}>
      <span class="brand__name">Santiago de Pablo</span>
      <span class="brand__suffix">Arquitectura</span>
    </a>

    <nav class="nav" aria-label="Principal">
      {nav.map((item) => (
        <a class="nav__link link-underline" href={item.href}>{t(lang, item.key)}</a>
      ))}
      <a class="nav__lang" href={altUrl} hreflang={other} lang={other} aria-label={`Cambiar idioma a ${other.toUpperCase()}`}>
        {t(lang, 'lang.switch')}
      </a>
    </nav>

    <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="mobile-nav">
      <span class="nav-toggle__label">{t(lang, 'nav.menu')}</span>
      <span class="nav-toggle__bars" aria-hidden="true"><i></i><i></i></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <div class="mobile-nav" id="mobile-nav" data-mobile-nav hidden>
    <nav class="mobile-nav__list" aria-label="Móvil">
      {nav.map((item) => (
        <a class="mobile-nav__link" href={item.href}>{t(lang, item.key)}</a>
      ))}
      <a class="mobile-nav__lang" href={altUrl} hreflang={other} lang={other}>
        {other === 'en' ? 'English' : 'Español'}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background 0.5s var(--ease), box-shadow 0.5s var(--ease);
  }
  .site-header.is-scrolled {
    background: color-mix(in srgb, var(--bone) 88%, transparent);
    backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 var(--line);
  }

  /* En páginas con hero oscuro, la cabecera va en blanco hasta hacer scroll */
  :global(html.is-dark-hero) .site-header:not(.is-scrolled) { color: #fff; }
  :global(html.is-dark-hero) .site-header:not(.is-scrolled) .brand__suffix { color: rgba(255,255,255,0.75); }
  :global(html.is-dark-hero) .site-header:not(.is-scrolled) .nav__lang { border-color: rgba(255,255,255,0.45); }
  :global(html.is-dark-hero) .site-header:not(.is-scrolled) .nav__lang:hover { background: #fff; color: var(--ink); border-color: #fff; }
  :global(html.is-dark-hero) .site-header:not(.is-scrolled) .nav-toggle__bars i { background: #fff; }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1rem, 2vw, 1.6rem);
  }
  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    font-family: var(--font-serif);
  }
  .brand__name { font-size: clamp(1.1rem, 0.9rem + 0.6vw, 1.35rem); letter-spacing: -0.01em; }
  .brand__suffix {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 0.15em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .nav__link { font-size: 0.98rem; }
  .nav__lang {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 0.35em 0.8em;
    transition: border-color 0.4s var(--ease), background 0.4s var(--ease);
  }
  .nav__lang:hover { border-color: var(--ink); background: var(--ink); color: var(--bone); }

  .nav-toggle {
    display: none;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }
  .nav-toggle__bars { display: inline-grid; gap: 5px; }
  .nav-toggle__bars i {
    display: block; width: 26px; height: 1.5px; background: var(--ink);
    transition: transform 0.4s var(--ease), opacity 0.3s;
  }
  .site-header.is-open .nav-toggle__bars i:nth-child(1) { transform: translateY(3.25px) rotate(45deg); }
  .site-header.is-open .nav-toggle__bars i:nth-child(2) { transform: translateY(-3.25px) rotate(-45deg); }

  .mobile-nav {
    position: fixed;
    inset: 0;
    background: var(--bone);
    z-index: 90;
    display: grid;
    place-items: center;
  }
  .mobile-nav[hidden] { display: none; }
  .mobile-nav__list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }
  .mobile-nav__link {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 1.4rem + 4vw, 3.4rem);
    font-weight: 360;
  }
  .mobile-nav__lang {
    margin-top: 1.5rem;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    border: 1px solid var(--ink);
    border-radius: 100px;
    padding: 0.6em 1.4em;
  }

  @media (max-width: 820px) {
    .nav { display: none; }
    .nav-toggle { display: inline-flex; position: relative; z-index: 95; }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const toggle = document.querySelector('[data-nav-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');

  // Cabecera con fondo al hacer scroll
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle('is-scrolled', window.scrollY > 24);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Menú móvil
  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
    if (mobileNav) {
      if (open) {
        mobileNav.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        mobileNav.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }
    }
  });
</script>
