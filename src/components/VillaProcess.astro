---
// Gráfico animado del proceso de trabajo del estudio: el diseño de una
// villa en Dubái se dibuja solo por fases (boceto → volumen → detalle →
// cotas) en bucle. Línea negra + acento azul, sin imágenes.
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const steps =
  lang === 'es'
    ? ['Boceto', 'Volumen', 'Detalle', 'Cotas']
    : ['Sketch', 'Massing', 'Detail', 'Dimensions'];
const caption =
  lang === 'es'
    ? 'Villa en Dubái — del boceto a la obra'
    : 'Villa in Dubai — from sketch to build';
---

<figure class="vp" aria-label={caption}>
  <div class="vp__sheet">
    <svg viewBox="0 0 400 500" role="img">
      <!-- 1 · retícula de construcción -->
      <g class="vp-grid">
        <path d="M20 340 H380" pathLength="100" />
        <path d="M60 90 V420" pathLength="100" />
        <path d="M340 90 V420" pathLength="100" />
        <path d="M24 430 L376 78" pathLength="100" />
        <circle cx="200" cy="255" r="140" pathLength="100" />
      </g>

      <!-- 1 · boceto a mano alzada -->
      <g class="vp-sk">
        <path d="M54 344 Q52 300 56 226 Q140 218 200 222 Q290 216 344 224 Q348 300 345 343 Q200 350 54 344 Z" pathLength="100" />
        <path d="M186 344 Q184 300 188 262 L228 260 Q231 300 229 343" pathLength="100" />
        <path d="M58 232 Q200 226 342 230" pathLength="100" />
      </g>

      <!-- 2 · volumetría limpia -->
      <g class="vp-vol">
        <path d="M60 230 H340 V340 H60 Z" pathLength="100" />
        <path d="M60 170 H340 V230 H60 Z" pathLength="100" />
        <path d="M188 340 V264 H230 V340" pathLength="100" />
        <path d="M252 340 V264 H328 V340" pathLength="100" />
        <path d="M20 340 H380" pathLength="100" />
      </g>

      <!-- 3 · detalle: lamas, puerta, vegetación, palmeras y sol -->
      <g class="vp-det">
        <path d="M72 174 V226 M84 174 V226 M96 174 V226 M108 174 V226 M120 174 V226 M132 174 V226 M144 174 V226 M156 174 V226 M168 174 V226 M180 174 V226 M192 174 V226 M204 174 V226 M216 174 V226 M228 174 V226 M240 174 V226 M252 174 V226 M264 174 V226 M276 174 V226 M288 174 V226 M300 174 V226 M312 174 V226 M324 174 V226 M332 174 V226" pathLength="100" />
        <path d="M196 272 V332 M204 272 V332 M212 272 V332 M220 272 V332" pathLength="100" />
        <path d="M100 340 V322 H152 V340" pathLength="100" />
        <path d="M104 322 Q110 306 118 320 Q126 302 134 319 Q140 308 148 321" pathLength="100" />
        <path d="M40 340 Q44 300 38 268" pathLength="100" />
        <path d="M38 268 Q18 260 8 272 M38 268 Q28 246 14 244 M38 268 Q48 244 62 246 M38 268 Q58 260 68 274" pathLength="100" />
        <path d="M362 340 Q358 296 366 262" pathLength="100" />
        <path d="M366 262 Q346 252 336 262 M366 262 Q356 240 342 238 M366 262 Q376 238 390 240 M366 262 Q386 254 394 266" pathLength="100" />
        <circle cx="330" cy="100" r="17" pathLength="100" />
      </g>

      <!-- 4 · cotas en azul -->
      <g class="vp-cota">
        <path d="M60 356 V368 M60 362 H340 M340 356 V368" pathLength="100" />
        <path d="M356 170 H368 M362 170 V340 M356 340 H368" pathLength="100" />
      </g>
      <text class="vp-cota-t vp-cota-t1" x="200" y="384" text-anchor="middle">24.00</text>
      <text class="vp-cota-t vp-cota-t2" x="372" y="258">8.50</text>
    </svg>
  </div>

  <figcaption class="vp__meta">
    <ol class="vp__steps">
      {steps.map((s, i) => (
        <li class:list={['vp__step', `vp__step--${i + 1}`]}>
          <span class="vp__num">{String(i + 1).padStart(2, '0')}</span> {s}
        </li>
      ))}
    </ol>
    <p class="vp__caption">{caption}</p>
  </figcaption>
</figure>

<style>
  .vp { width: 100%; display: flex; flex-direction: column; }
  .vp__sheet {
    border: 1px solid var(--line);
    background: var(--bone);
    aspect-ratio: 4 / 5;
  }
  .vp__sheet svg { display: block; width: 100%; height: 100%; }
  /* En escritorio la lámina estira hasta alinear con el final del texto */
  @media (min-width: 821px) {
    .vp { height: 100%; }
    .vp__sheet { aspect-ratio: auto; flex: 1; min-height: 240px; }
    .vp__meta { flex-shrink: 0; }
  }

  /* trazos base */
  .vp-grid :is(path, circle) { stroke: #c9c9c4; stroke-width: 0.8; fill: none; }
  .vp-sk path { stroke: var(--ink); stroke-width: 1.1; fill: none; stroke-linecap: round; }
  .vp-vol path { stroke: var(--ink); stroke-width: 1.7; fill: none; }
  .vp-det :is(path, circle) { stroke: var(--ink); stroke-width: 1.05; fill: none; stroke-linecap: round; }
  .vp-cota path { stroke: var(--accent); stroke-width: 1.1; fill: none; }
  .vp-cota-t {
    fill: var(--accent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  /* dibujo por fases: dash sobre pathLength 100, ciclo de 14s */
  .vp :is(path, circle) { stroke-dasharray: 100; }
  .vp-grid :is(path, circle) { animation: vpGrid 14s linear infinite; }
  .vp-sk path { animation: vpSk 14s linear infinite; }
  .vp-vol path { animation: vpVol 14s linear infinite; }
  .vp-det :is(path, circle) { animation: vpDet 14s linear infinite; }
  .vp-cota path { animation: vpCota 14s linear infinite; }
  .vp-cota-t { animation: vpCotaT 14s linear infinite; }

  @keyframes vpGrid {
    0% { stroke-dashoffset: 100; opacity: 1; }
    9% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 0.55; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpSk {
    0%, 6% { stroke-dashoffset: 100; opacity: 1; }
    20% { stroke-dashoffset: 0; opacity: 1; }
    30% { opacity: 1; }
    40% { opacity: 0.18; } /* el boceto queda como fantasma */
    88% { stroke-dashoffset: 0; opacity: 0.18; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpVol {
    0%, 24% { stroke-dashoffset: 100; opacity: 1; }
    44% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpDet {
    0%, 44% { stroke-dashoffset: 100; opacity: 1; }
    70% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpCota {
    0%, 70% { stroke-dashoffset: 100; opacity: 1; }
    80% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpCotaT {
    0%, 76% { opacity: 0; }
    82%, 88% { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  /* pasos del proceso */
  .vp__meta { margin-top: 0.9rem; }
  .vp__steps {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    padding: 0;
  }
  .vp__step {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    opacity: 0.32;
  }
  .vp__num { color: var(--accent); margin-right: 0.2em; }
  .vp__step--1 { animation: vpS1 14s linear infinite; }
  .vp__step--2 { animation: vpS2 14s linear infinite; }
  .vp__step--3 { animation: vpS3 14s linear infinite; }
  .vp__step--4 { animation: vpS4 14s linear infinite; }
  @keyframes vpS1 { 0% { opacity: 1; } 22% { opacity: 1; } 26%, 100% { opacity: 0.32; } }
  @keyframes vpS2 { 0%, 22% { opacity: 0.32; } 26% { opacity: 1; } 44% { opacity: 1; } 48%, 100% { opacity: 0.32; } }
  @keyframes vpS3 { 0%, 44% { opacity: 0.32; } 48% { opacity: 1; } 70% { opacity: 1; } 74%, 100% { opacity: 0.32; } }
  @keyframes vpS4 { 0%, 70% { opacity: 0.32; } 74% { opacity: 1; } 90% { opacity: 1; } 94%, 100% { opacity: 0.32; } }

  .vp__caption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .vp :is(path, circle, text),
    .vp__step { animation: none !important; opacity: 1; }
    .vp-sk path { opacity: 0.18; }
  }
</style>
