---
// Lámina animada del proceso creativo del estudio, en abstracto:
// una idea que nace → exploración geométrica → líneas de orden →
// precisión. Figuras puras, sin proyecto concreto. Solo SVG + CSS.
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const steps =
  lang === 'es'
    ? ['Idea', 'Geometría', 'Orden', 'Precisión']
    : ['Idea', 'Geometry', 'Order', 'Precision'];
const caption =
  lang === 'es' ? 'Del concepto a la forma' : 'From concept to form';
---

<figure class="vp" aria-label={caption}>
  <div class="vp__sheet">
    <svg viewBox="0 0 400 500" role="img">
      <!-- 1 · la idea: un punto, un círculo, destellos -->
      <g class="vp-a">
        <circle class="vp-dot" cx="200" cy="240" r="4" pathLength="100" />
        <circle cx="200" cy="240" r="58" pathLength="100" />
        <path d="M266 240 H276 M247 193 L254 186 M200 174 V164 M153 193 L146 186 M134 240 H124 M153 287 L146 294 M200 306 V316 M247 287 L254 294" pathLength="100" />
      </g>

      <!-- 2 · exploración geométrica: figuras superpuestas -->
      <g class="vp-b">
        <circle cx="200" cy="240" r="125" pathLength="100" />
        <path d="M125 165 H275 V315 H125 Z" pathLength="100" />
        <path d="M200 115 L325 240 L200 365 L75 240 Z" pathLength="100" />
        <path d="M115 388 L285 388 L200 240 Z" pathLength="100" />
      </g>

      <!-- 3 · líneas de orden -->
      <g class="vp-c">
        <path d="M200 70 V440" pathLength="100" />
        <path d="M55 240 H345" pathLength="100" />
        <path d="M96 136 L304 344" pathLength="100" />
        <path d="M304 136 L96 344" pathLength="100" />
        <path d="M75 90 H95 M75 90 V110 M325 90 H305 M325 90 V110 M75 390 H95 M75 390 V370 M325 390 H305 M325 390 V370" pathLength="100" />
      </g>

      <!-- 4 · precisión: arcos y puntos en azul, proporción -->
      <g class="vp-d">
        <circle cx="200" cy="240" r="8" pathLength="100" />
        <circle class="vp-arc vp-arc1" cx="200" cy="240" r="88" pathLength="100" />
        <circle class="vp-arc vp-arc2" cx="200" cy="240" r="112" pathLength="100" />
        <circle class="vp-arc vp-arc3" cx="200" cy="240" r="136" pathLength="100" />
        <path d="M120 462 V472 M120 467 H280 M280 462 V472" pathLength="100" />
      </g>
      <circle class="vp-pt vp-pt1" cx="200" cy="115" r="3.4" />
      <circle class="vp-pt vp-pt2" cx="325" cy="240" r="3.4" />
      <circle class="vp-pt vp-pt3" cx="75" cy="240" r="3.4" />
      <text class="vp-ratio" x="200" y="488" text-anchor="middle">1 : 1.618</text>
    </svg>
  </div>

  <figcaption class="vp__meta">
    <ol class="vp__steps">
      {steps.map((s, i) => (
        <li class:list={['vp__step', `vp__step--${i + 1}`]}>
          <span class="vp__num">{String(i + 1).padStart(2, '0')}</span> {s}
        </li>
      ))}
    </ol>
    <p class="vp__caption">{caption}</p>
  </figcaption>
</figure>

<style>
  .vp { width: 100%; display: flex; flex-direction: column; }
  .vp__sheet {
    border: 1px solid var(--line);
    background: var(--bone);
    aspect-ratio: 4 / 5;
  }
  .vp__sheet svg { display: block; width: 100%; height: 100%; }
  /* En escritorio la lámina estira hasta alinear con el final del texto */
  @media (min-width: 821px) {
    .vp { height: 100%; }
    .vp__sheet { aspect-ratio: auto; flex: 1; min-height: 240px; }
    .vp__meta { flex-shrink: 0; }
  }

  /* trazos */
  .vp-a :is(path, circle) { stroke: var(--ink); stroke-width: 1.4; fill: none; stroke-linecap: round; }
  .vp-a .vp-dot { fill: var(--ink); stroke: none; }
  .vp-b :is(path, circle) { stroke: var(--ink); stroke-width: 1.05; fill: none; }
  .vp-c path { stroke: #c9c9c4; stroke-width: 0.9; fill: none; }
  .vp-d :is(path, circle) { stroke: var(--accent); stroke-width: 1.3; fill: none; }
  .vp-pt { fill: var(--accent); }
  .vp-ratio {
    fill: var(--accent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
  }
  /* arcos abiertos que orbitan el centro */
  .vp-arc1 { stroke-dasharray: 26 74 !important; rotate: -20deg; }
  .vp-arc2 { stroke-dasharray: 18 82 !important; rotate: 130deg; }
  .vp-arc3 { stroke-dasharray: 22 78 !important; rotate: 250deg; }
  .vp-arc { transform-box: fill-box; transform-origin: 50% 50%; }

  /* dibujo por fases: ciclo de 14s */
  .vp :is(path, circle) { stroke-dasharray: 100; }
  .vp-a :is(path, circle) { animation: vpA 14s linear infinite; }
  .vp-b :is(path, circle) { animation: vpB 14s linear infinite; }
  .vp-c path { animation: vpC 14s linear infinite; }
  .vp-d :is(path, circle) { animation: vpD 14s linear infinite; }
  .vp-arc1 { animation: vpArc1 14s linear infinite; }
  .vp-arc2 { animation: vpArc2 14s linear infinite; }
  .vp-arc3 { animation: vpArc3 14s linear infinite; }
  .vp-pt, .vp-ratio { opacity: 0; animation: vpPt 14s linear infinite; }
  .vp-pt2 { animation-delay: 0.25s; }
  .vp-pt3 { animation-delay: 0.5s; }

  @keyframes vpA {
    0% { stroke-dashoffset: 100; opacity: 1; }
    10% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpB {
    0%, 12% { stroke-dashoffset: 100; opacity: 1; }
    38% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpC {
    0%, 40% { stroke-dashoffset: 100; opacity: 1; }
    58% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 0.7; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes vpD {
    0%, 60% { stroke-dashoffset: 100; opacity: 1; }
    76% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  /* los arcos azules giran lentamente mientras viven */
  @keyframes vpArc1 {
    0%, 60% { stroke-dashoffset: 100; opacity: 1; rotate: -20deg; }
    76% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; rotate: 14deg; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; rotate: 20deg; }
  }
  @keyframes vpArc2 {
    0%, 60% { stroke-dashoffset: 100; opacity: 1; rotate: 130deg; }
    76% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; rotate: 104deg; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; rotate: 98deg; }
  }
  @keyframes vpArc3 {
    0%, 60% { stroke-dashoffset: 100; opacity: 1; rotate: 250deg; }
    76% { stroke-dashoffset: 0; }
    88% { stroke-dashoffset: 0; opacity: 1; rotate: 274deg; }
    94%, 100% { stroke-dashoffset: 0; opacity: 0; rotate: 280deg; }
  }
  @keyframes vpPt {
    0%, 64% { opacity: 0; }
    70%, 88% { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  /* pasos del proceso */
  .vp__meta { margin-top: 0.9rem; }
  .vp__steps {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    padding: 0;
  }
  .vp__step {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    opacity: 0.32;
  }
  .vp__num { color: var(--accent); margin-right: 0.2em; }
  .vp__step--1 { animation: vpS1 14s linear infinite; }
  .vp__step--2 { animation: vpS2 14s linear infinite; }
  .vp__step--3 { animation: vpS3 14s linear infinite; }
  .vp__step--4 { animation: vpS4 14s linear infinite; }
  @keyframes vpS1 { 0% { opacity: 1; } 12% { opacity: 1; } 16%, 100% { opacity: 0.32; } }
  @keyframes vpS2 { 0%, 12% { opacity: 0.32; } 16% { opacity: 1; } 40% { opacity: 1; } 44%, 100% { opacity: 0.32; } }
  @keyframes vpS3 { 0%, 40% { opacity: 0.32; } 44% { opacity: 1; } 60% { opacity: 1; } 64%, 100% { opacity: 0.32; } }
  @keyframes vpS4 { 0%, 60% { opacity: 0.32; } 64% { opacity: 1; } 90% { opacity: 1; } 94%, 100% { opacity: 0.32; } }

  .vp__caption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .vp :is(path, circle, text),
    .vp__step { animation: none !important; opacity: 1; }
    .vp-c path { opacity: 0.7; }
  }
</style>
