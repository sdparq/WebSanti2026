---
// Lámina animada de la página de Estudio: un boceto arquitectónico
// abstracto, a mano alzada, dibujado EN DIRECTO por una pluma visible.
// La tinta aparece exactamente bajo la punta: pluma y trazo comparten
// el mismo reloj y la misma geometría (sincronizado por JS).
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const caption =
  lang === 'es' ? 'El trazo — pensar dibujando' : 'The line — thinking by drawing';

// Trazos del boceto, en orden de dibujo (uno por path para poder
// revelarlos exactamente al paso de la pluma).
const SEGS = [
  // horizonte
  'M30 330 Q120 324 200 329 Q300 334 372 328',
  // guías de fuga sueltas
  'M42 329 Q200 288 358 252',
  'M42 329 Q190 362 352 392',
  // volumen principal en perspectiva
  'M210 180 Q212 240 209 302',
  'M210 182 Q150 194 96 208',
  'M210 182 Q280 172 330 166',
  'M96 208 Q98 250 95 292',
  'M330 166 Q332 230 331 300',
  'M95 292 Q150 298 209 302',
  'M331 300 Q272 304 209 302',
  // volumen bajo a la izquierda
  'M60 260 Q86 240 112 250',
  'M112 250 Q113 272 111 294',
  'M60 260 Q61 278 59 296',
  'M59 296 Q86 297 111 294',
  // hueco en la cara frontal
  'M150 236 Q151 260 149 282',
  'M180 232 Q181 258 179 280',
  'M150 236 Q165 232 180 232',
  // sombreado a rayitas, trazo a trazo
  'M300 200 L318 194',
  'M296 216 L322 208',
  'M294 232 L326 222',
  'M293 248 L328 237',
  'M293 264 L329 252',
  'M294 280 L330 266',
  // árbol y figura de escala
  'M348 300 Q349 286 347 274',
  'M347 274 Q336 260 348 254 Q360 260 347 274',
  'M132 316 Q132 306 133 300',
  'M133 297 Q136 294 133 291 Q130 294 133 297',
  // sol garabateado
  'M320 96 Q332 86 340 98 Q346 110 334 114 Q324 117 319 108 Q316 100 323 97',
  // subrayado final, casi firma
  'M60 430 Q140 423 220 428 Q300 433 344 427',
];
---

<figure class="vp" aria-label={caption}>
  <div class="vp__sheet">
    <svg viewBox="24 78 356 362" preserveAspectRatio="xMidYMin meet" role="img" data-sketch>
      <g class="vp-ink" data-ink>
        {SEGS.map((d) => <path class="vp-seg" d={d} />)}
      </g>
      <g class="vp-pen" data-pen aria-hidden="true">
        <path class="vp-pen__shaft" d="M2 -3 L13 -14" />
        <circle class="vp-pen__nib" r="3.2" />
      </g>
    </svg>
  </div>

  <figcaption class="vp__meta">
    <p class="vp__caption">{caption}</p>
  </figcaption>
</figure>

<style>
  .vp { width: 100%; display: flex; flex-direction: column; }
  .vp__sheet {
    aspect-ratio: 1 / 1;
  }
  .vp__sheet svg { display: block; width: 100%; height: 100%; }
  /* En escritorio la lámina estira hasta alinear con el final del texto */
  @media (min-width: 821px) {
    .vp { height: 100%; }
    .vp__sheet { aspect-ratio: auto; flex: 1; min-height: 240px; }
    .vp__meta { flex-shrink: 0; }
  }

  .vp-seg {
    stroke: var(--ink);
    stroke-width: 1.3;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .vp-pen__nib { fill: var(--accent); }
  .vp-pen__shaft {
    stroke: var(--ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    fill: none;
  }

  .vp__meta { margin-top: 0.9rem; }
  .vp__caption {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }
</style>

<script>
  // La pluma dibuja: recorremos los trazos por longitud real y revelamos
  // la tinta exactamente hasta el punto donde está la punta.
  const svg = document.querySelector<SVGSVGElement>('[data-sketch]');
  if (svg) {
    const segs = Array.from(svg.querySelectorAll<SVGPathElement>('.vp-seg'));
    const ink = svg.querySelector<SVGGElement>('[data-ink]')!;
    const pen = svg.querySelector<SVGGElement>('[data-pen]')!;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const lens = segs.map((s) => s.getTotalLength());
    const starts: number[] = [];
    let total = 0;
    for (const L of lens) { starts.push(total); total += L; }
    segs.forEach((s, i) => {
      s.style.strokeDasharray = `${lens[i]}`;
      s.style.strokeDashoffset = `${lens[i]}`;
    });

    if (reduce) {
      // Sin animación: boceto completo, sin pluma
      segs.forEach((s) => (s.style.strokeDashoffset = '0'));
      pen.style.display = 'none';
    } else {
      const T = 16;            // ciclo completo (s)
      const DRAW = 0.78 * T;   // la pluma dibuja
      const HOLD = 0.9 * T;    // lámina terminada
      const FADE = 0.96 * T;   // se desvanece
      let t0 = 0;

      const frame = (now: number) => {
        if (!t0) t0 = now;
        const t = ((now - t0) / 1000) % T;

        if (t < DRAW) {
          ink.style.opacity = '1';
          const s = (t / DRAW) * total; // longitud ya dibujada
          let px = 0, py = 0;
          for (let i = 0; i < segs.length; i++) {
            if (s >= starts[i] + lens[i]) {
              segs[i].style.strokeDashoffset = '0';
            } else if (s <= starts[i]) {
              segs[i].style.strokeDashoffset = `${lens[i]}`;
            } else {
              const local = s - starts[i];
              segs[i].style.strokeDashoffset = `${lens[i] - local}`;
              const pt = segs[i].getPointAtLength(local);
              px = pt.x; py = pt.y;
            }
          }
          if (px || py) {
            pen.style.display = '';
            pen.style.opacity = '1';
            pen.setAttribute('transform', `translate(${px} ${py})`);
          }
        } else {
          // terminada: pluma fuera, todo dibujado; luego fundido y reinicio
          pen.style.opacity = '0';
          segs.forEach((sg) => (sg.style.strokeDashoffset = '0'));
          if (t < HOLD) ink.style.opacity = '1';
          else if (t < FADE) ink.style.opacity = `${1 - (t - HOLD) / (FADE - HOLD)}`;
          else ink.style.opacity = '0';
        }
        requestAnimationFrame(frame);
      };
      requestAnimationFrame(frame);
    }
  }
</script>
