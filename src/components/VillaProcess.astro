---
// Lámina animada de la página de Estudio: un boceto arquitectónico
// abstracto, a mano alzada, dibujado en directo por una pluma visible
// que recorre cada trazo (y "se levanta" entre trazos). SVG + CSS.
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const caption =
  lang === 'es' ? 'El trazo — pensar dibujando' : 'The line — thinking by drawing';

// Todos los trazos del boceto, en orden de dibujo, como un único camino.
// La misma geometría guía la tinta (dash) y el recorrido de la pluma.
const D = [
  // horizonte
  'M30 330 Q120 324 200 329 Q300 334 372 328',
  // guías de fuga sueltas
  'M42 329 Q200 288 358 252',
  'M42 329 Q190 362 352 392',
  // volumen principal en perspectiva
  'M210 180 Q212 240 209 302',
  'M210 182 Q150 194 96 208',
  'M210 182 Q280 172 330 166',
  'M96 208 Q98 250 95 292',
  'M330 166 Q332 230 331 300',
  'M95 292 Q150 298 209 302',
  'M331 300 Q272 304 209 302',
  // volumen bajo a la izquierda
  'M60 260 Q86 240 112 250',
  'M112 250 Q113 272 111 294',
  'M60 260 Q61 278 59 296',
  'M59 296 Q86 297 111 294',
  // hueco en la cara frontal
  'M150 236 Q151 260 149 282',
  'M180 232 Q181 258 179 280',
  'M150 236 Q165 232 180 232',
  // sombreado a rayitas en la cara derecha
  'M300 200 L318 194 M296 216 L322 208 M294 232 L326 222 M293 248 L328 237 M293 264 L329 252 M294 280 L330 266',
  // árbol y figura de escala
  'M348 300 Q349 286 347 274',
  'M347 274 Q336 260 348 254 Q360 260 347 274',
  'M132 316 Q132 306 133 300',
  'M133 297 Q136 294 133 291 Q130 294 133 297',
  // sol garabateado
  'M320 96 Q332 86 340 98 Q346 110 334 114 Q324 117 319 108 Q316 100 323 97',
  // subrayado final, casi firma
  'M60 430 Q140 423 220 428 Q300 433 344 427',
].join(' ');
---

<figure class="vp" aria-label={caption}>
  <div class="vp__sheet">
    <svg viewBox="0 0 400 500" role="img" style={`--sketch: path('${D}')`}>
      <path class="vp-ink" d={D} pathLength="100" />
      <g class="vp-pen" aria-hidden="true">
        <path class="vp-pen__shaft" d="M2 -3 L13 -14" />
        <circle class="vp-pen__nib" r="3.2" />
      </g>
    </svg>
  </div>

  <figcaption class="vp__meta">
    <p class="vp__caption">{caption}</p>
  </figcaption>
</figure>

<style>
  .vp { width: 100%; display: flex; flex-direction: column; }
  .vp__sheet {
    border: 1px solid var(--line);
    background: var(--bone);
    aspect-ratio: 4 / 5;
  }
  .vp__sheet svg { display: block; width: 100%; height: 100%; }
  /* En escritorio la lámina estira hasta alinear con el final del texto */
  @media (min-width: 821px) {
    .vp { height: 100%; }
    .vp__sheet { aspect-ratio: auto; flex: 1; min-height: 240px; }
    .vp__meta { flex-shrink: 0; }
  }

  /* tinta: trazo a mano alzada que se dibuja en orden */
  .vp-ink {
    stroke: var(--ink);
    stroke-width: 1.3;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 100;
    animation: vpInk 16s linear infinite;
  }
  @keyframes vpInk {
    0% { stroke-dashoffset: 100; opacity: 1; }
    78% { stroke-dashoffset: 0; opacity: 1; }
    90% { stroke-dashoffset: 0; opacity: 1; }
    96%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }

  /* la pluma: sigue exactamente el mismo camino que la tinta */
  .vp-pen { display: none; }
  @supports (offset-path: path('M0 0 L1 1')) {
    .vp-pen {
      display: block;
      offset-path: var(--sketch);
      offset-rotate: 0deg;
      animation: vpPen 16s linear infinite;
    }
  }
  .vp-pen__nib { fill: var(--accent); }
  .vp-pen__shaft {
    stroke: var(--ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    fill: none;
  }
  @keyframes vpPen {
    0% { offset-distance: 0%; opacity: 1; }
    78% { offset-distance: 100%; opacity: 1; }
    82% { offset-distance: 100%; opacity: 0; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  .vp__meta { margin-top: 0.9rem; }
  .vp__caption {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .vp-ink { animation: none !important; stroke-dashoffset: 0; }
    .vp-pen { display: none !important; }
  }
</style>
